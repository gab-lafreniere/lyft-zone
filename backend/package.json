{
  "name": "lyft-zone-backend",
  "version": "1.0.0",
  "description": "Backend for Lyft Zone training app",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test:prisma-api-flow": "node scripts/test-prisma-api-flow.js",
    "validate:exercises": "node src/exercise-library/validate-exercises.js",
    "seed:exercises": "node prisma/seed-exercises.js",
    "seed:exercises:dry": "node prisma/seed-exercises.js --dry-run",
    "postinstall": "prisma generate --config ./prisma.config.ts"
  },
  "prisma": {
    "seed": "node prisma/seed-exercises.js"
  },
  "keywords": [
    "express",
    "sqlite",
    "sequelize"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "sequelize": "^6.35.2",
    "sqlite3": "^5.1.6"
  }
}
