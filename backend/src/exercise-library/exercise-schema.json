{
    "requiredFields": [
      "exerciseId",
      "name",
      "equipmentCategory",
      "equipmentNeeded",
      "movementPattern",
      "bodyParts",
      "muscleFocus",
      "targetMuscles",
      "secondaryMuscles",
      "muscleActivation",
      "mechanicType",
      "unilateralType",
      "difficulty",
      "trainingType",
      "keywords",
      "overview",
      "coachingCues",
      "commonMistakes",
      "isSupersetFriendly",
      "fatigueScore",
      "status"
    ],
    "optionalFields": [
      "aliases"
    ],
    "fieldTypes": {
      "exerciseId": "string",
      "name": "string",
      "aliases": "string[]",
      "equipmentCategory": "enum:equipmentCategory",
      "equipmentNeeded": "enum[]:equipmentNeeded",
      "movementPattern": "enum:movementPattern",
      "bodyParts": "enum[]:bodyParts",
      "muscleFocus": "enum[]:muscleFocus",
      "targetMuscles": "enum[]:muscles",
      "secondaryMuscles": "enum[]:muscles",
      "muscleActivation": "record<muscles, muscleActivationValues>",
      "mechanicType": "enum:mechanicType",
      "unilateralType": "enum:unilateralType",
      "difficulty": "enum:difficulty",
      "trainingType": "enum:trainingType",
      "keywords": "string[]",
      "overview": "string",
      "coachingCues": "string[]",
      "commonMistakes": "string[]",
      "isSupersetFriendly": "boolean",
      "fatigueScore": "integer",
      "status": "enum:status"
    },
    "rules": [
      "exerciseId must be unique",
      "exerciseId must start with exr_",
      "exerciseId must use snake_case",
      "equipmentNeeded must contain at least 1 item",
      "bodyParts must contain at least 1 item",
      "muscleFocus may be empty",
      "muscleFocus must not contain duplicates",
      "if present, every muscleFocus value must be valid",
      "targetMuscles must contain at least 1 item",
      "targetMuscles must not contain duplicates",
      "secondaryMuscles must not contain duplicates",
      "targetMuscles and secondaryMuscles must not overlap",
      "every muscleActivation key must exist in targetMuscles or secondaryMuscles",
      "every targetMuscle must exist in muscleActivation",
      "muscleActivation values must be one of 0.25, 0.5, 0.75, 1.0",
      "at least one target muscle should have activation 1.0",
      "fatigueScore must be between 1 and 5"
    ]
  }