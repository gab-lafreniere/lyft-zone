# Environment Variables for Lyft Zone Backend
# Copy this file to .env and update values as needed

PORT=5000
DATABASE_URL=./database.sqlite
NODE_ENV=development

# AI Weekly Plan Builder V1 review (production-ready only when enabled)
ENABLE_AI_WEEKLY_PLAN_REVIEW=false
OPENAI_MODEL_PROGRAM_REVIEW=
OPENAI_PROGRAM_REVIEW_TIMEOUT_MS=60000
OPENAI_PROGRAM_REVIEW_MAX_OUTPUT_TOKENS=4000
